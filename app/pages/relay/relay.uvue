<template>
	<scroll-view class="page" :class="isDark ? 'theme-dark' : 'theme-light'" style="flex:1">
		<view class="wrap">
			<text class="h1" style="margin-bottom:16px;">中继配置</text>

			<view v-if="!connected" class="card">
				<text class="muted" style="margin-bottom:12px;">{{ errText }}</text>
				<button class="btn-blue" @click="goPair">去配对</button>
			</view>

			<view v-else>
				<view class="card between">
					<view>
						<text class="title">启用</text>
						<text class="muted-sm" style="margin-top:3px;">实时作用于桌面</text>
					</view>
					<text :class="enabled ? 'badge-on' : 'badge-off'">{{ enabled ? '开启' : '关闭' }}</text>
				</view>

				<text class="section">上游</text>
				<view class="card" style="padding-top:2px;padding-bottom:2px;">
					<view class="rowb"><text class="label">Base URL</text><text class="val">{{ upstream }}</text></view>
					<view class="rowb"><text class="label">协议</text><text class="pill">{{ upstreamApi }}</text></view>
					<view class="row"><text class="label">API Key</text><text class="val">{{ apiKeyMasked }}</text></view>
				</view>

				<text class="section">模型路由 · 配置（点目标切换，影响之后的调用）</text>
				<view class="card">
					<view v-if="modelRows.length == 0"><text class="muted">无</text></view>
					<view v-for="(m, idx) in modelRows" :key="idx" class="uni-row vcenter" style="padding-top:6px;padding-bottom:6px;" @click="cycleModel(idx)">
						<text class="pill-gray">{{ m.from }}</text>
						<text class="arrow" style="margin-left:8px;margin-right:8px;">→</text>
						<text class="pill">{{ m.to }}</text>
						<text class="muted-sm" style="margin-left:auto;">切换 ›</text>
					</view>
					<text v-if="ctrlMsg != ''" class="val-blue" style="margin-top:8px;">{{ ctrlMsg }}</text>
				</view>

				<text class="section">预算</text>
				<view class="card" style="padding-top:2px;padding-bottom:2px;">
					<view class="rowb"><text class="label">每日上限</text><text class="val">{{ dailyText }}</text></view>
					<view class="rowb"><text class="label">每月上限</text><text class="val">{{ monthlyText }}</text></view>
					<view class="row"><text class="label">今日 / 本月</text><text class="val">{{ spentText }}</text></view>
				</view>

				<view class="card" style="padding-top:2px;padding-bottom:2px;">
					<view class="rowb"><text class="label">路由 / 护栏</text><text class="val">{{ routesText }}</text></view>
					<view class="row"><text class="label">远程控制</text><text class="val-green">已启用（点上方模型切换）</text></view>
				</view>

				<button class="btn-line" @click="load">刷新</button>
			</view>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
	import { request, isConnected, autoConnect, savedLink } from "@/common/store.uts"
	import { isDarkNow, applyChrome } from "@/common/theme.uts"

	type MapRow = { from : string; to : string }

	const isDark = ref(false)

	const connected = ref(false)
	const errText = ref("未连接，请先配对")
	const enabled = ref(false)
	const upstream = ref("—")
	const upstreamApi = ref("—")
	const apiKeyMasked = ref("—")
	const modelRows = ref<MapRow[]>([])
	const dailyText = ref("无")
	const monthlyText = ref("无")
	const spentText = ref("—")
	const routesText = ref("0 / 0")
	const ctrlMsg = ref("")

	const PRESETS : string[] = ["deepseek-v4-flash", "deepseek-v4-proz", "deepseek-reasoner"]

	function load() {
		if (!isConnected()) {
			connected.value = false
			errText.value = "未连接，请先配对"
			return
		}
		connected.value = true
		request("relay.summary", null).then((r : any) : void => {
			const o = JSON.parse(JSON.stringify(r)) as UTSJSONObject
			enabled.value = o.getBoolean("enabled") == true
			upstream.value = o.getString("upstream") ?? "—"
			upstreamApi.value = o.getString("upstreamApi") ?? "—"
			apiKeyMasked.value = o.getString("apiKeyMasked") ?? "—"
			const mm = o.getJSON("modelMap")
			const rows : MapRow[] = []
			if (mm != null) {
				const m = mm!.toMap()
				m.forEach((v : any, k : string) : void => {
					rows.push({ from: k, to: v as string } as MapRow)
				})
			}
			modelRows.value = rows
			routesText.value = (o.getNumber("routes") ?? 0).toString() + " / " + (o.getNumber("guardrails") ?? 0).toString()
			const b = o.getJSON("budget")
			if (b != null) {
				const daily = b!.getNumber("dailyUsd")
				const monthly = b!.getNumber("monthlyUsd")
				dailyText.value = daily != null ? ("$" + daily!.toString()) : "无"
				monthlyText.value = monthly != null ? ("$" + monthly!.toString()) : "无"
				spentText.value = "$" + (b!.getNumber("daySpent") ?? 0).toString() + " / $" + (b!.getNumber("monthSpent") ?? 0).toString()
			} else {
				dailyText.value = "无"
				monthlyText.value = "无"
				spentText.value = "—"
			}
		}).catch((e : any) : void => {
			errText.value = "查询失败: " + e
			connected.value = false
		})
	}

	onShow(() => {
		isDark.value = isDarkNow()
		applyChrome(isDark.value, true)
		if (isConnected()) {
			load()
		} else {
			connected.value = false
			errText.value = "连接中…"
			const started = autoConnect((s : string) : void => {
				errText.value = s
				if (s.indexOf("authed") >= 0) {
					load()
				}
			})
			if (!started && savedLink() == "") {
				errText.value = "未连接，请先配对"
			}
		}
	})

	const goPair = () => {
		uni.navigateTo({ url: "/pages/pair/pair" } as NavigateToOptions)
	}

	function nextModel(cur : string) : string {
		for (let i = 0; i < PRESETS.length; i++) {
			if (PRESETS[i] == cur) {
				return PRESETS[(i + 1) % PRESETS.length]
			}
		}
		return PRESETS[0]
	}

	// 点击某条路由 → 切换目标模型 → config.set 实时下发到桌面。
	const cycleModel = (idx : number) => {
		const rows = modelRows.value
		const newRows : MapRow[] = []
		for (let i = 0; i < rows.length; i++) {
			if (i == idx) {
				newRows.push({ from: rows[i].from, to: nextModel(rows[i].to) } as MapRow)
			} else {
				newRows.push(rows[i])
			}
		}
		modelRows.value = newRows

		let mm = "{"
		for (let i = 0; i < newRows.length; i++) {
			if (i > 0) {
				mm += ","
			}
			mm += "\"" + newRows[i].from + "\":\"" + newRows[i].to + "\""
		}
		mm += "}"
		ctrlMsg.value = "更新中…"
		request("config.set", JSON.parseObject("{\"relay\":{\"modelMap\":" + mm + "}}")).then((_r : any) : void => {
			ctrlMsg.value = "已应用到桌面 ✓"
		}).catch((e : any) : void => {
			ctrlMsg.value = "失败: " + e
		})
	}
</script>
