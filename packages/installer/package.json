{
  "name": "@desktop-proxy/installer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI tool for patching/unpatching Electron apps with the desktop-proxy injection framework",
  "main": "dist/cli.js",
  "bin": {
    "desktop-proxy": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@desktop-proxy/plugin-sdk": "workspace:*",
    "@electron/asar": "^4.2",
    "nats-jwt": "^0.0.9",
    "nkeys.js": "^1.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^6.0"
  }
}
